local function hideSlot(s)
    if not s then return end
    s.name_lbl.Visible=false; s.tracer.Visible=false; s.box.Visible=false
    for _,l in ipairs(s.corners) do l.Visible=false end
end

local function removeSlot(name)
    local s = espObjects[name]
    if not s then return end
    pcall(function() s.name_lbl:Remove() end)
    pcall(function() s.tracer:Remove() end)
    pcall(function() s.box:Remove() end)
    for _,l in ipairs(s.corners) do pcall(function() l:Remove() end) end
    espObjects[name]=nil; espData[name]=nil; dribData[name]=nil
end

