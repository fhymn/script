-- ============================================================
-- Memory helpers
-- ============================================================
local function getMemBase(inst)
    local ok, prim = pcall(function() return memory_read("uintptr_t", inst.Address + 0x148) end)
    if ok and prim and prim ~= 0 then return prim + 0xC0 end
    return nil
end
local function readPosMem(base)
    return memory_read("float",base+36), memory_read("float",base+40), memory_read("float",base+44)
end
local function writePosBase(base,x,y,z)
    memory_write("float",base+36,x); memory_write("float",base+40,y); memory_write("float",base+44,z)
end
local function readPosInst(inst)
    local ok, prim = pcall(function() return memory_read("uintptr_t", inst.Address + 0x148) end)
    if ok and prim and prim ~= 0 then
        local base = prim + 0xC0
        local ok1,x=pcall(function() return memory_read("float",base+36) end)
        local ok2,y=pcall(function() return memory_read("float",base+40) end)
        local ok3,z=pcall(function() return memory_read("float",base+44) end)
        if ok1 and ok2 and ok3 then return x,y,z end
    end
    local pok,pos=pcall(function() return inst.Position end)
    if pok then return pos.X,pos.Y,pos.Z end
    return nil
end
local function easeInOut(t) return t*t*(3-2*t) end

