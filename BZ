-- ESP + Auto Dribble loop
-- ============================================================
task.spawn(function()
    while running do
        local now = tick()

        -- Ball ESP
        if get("ball_esp") then
            local ball = getBall()
            if ball then
                local bpos = ball.Position
                local sp, onScreen = WorldToScreen(bpos)
                if onScreen then
                    local hrp  = getHRP()
                    local dist = 0
                    if hrp then
                        local hp = hrp.Position
                        dist = math.floor(math.sqrt((bpos.X-hp.X)^2+(bpos.Y-hp.Y)^2+(bpos.Z-hp.Z)^2))
                    end
                    local cp = camera.Position
                    local cd = math.max(1, math.sqrt((bpos.X-cp.X)^2+(bpos.Y-cp.Y)^2+(bpos.Z-cp.Z)^2))
                    local bs = math.max(8, math.min(60, 3000/cd))
                    local hf = bs/2
                    local col = getColor("ball_col")
                    local vp  = camera.ViewportSize
                    ballBox.Color=col; ballBox.Position=Vector2.new(sp.X-hf,sp.Y-hf)
                    ballBox.Size=Vector2.new(bs,bs); ballBox.Visible=true
                    ballLabel.Text=dist.."m"; ballLabel.Color=Color3.fromRGB(255,255,255)
                    ballLabel.Position=Vector2.new(sp.X,sp.Y-hf-16); ballLabel.Visible=true
                    if get("plr_tracer") then
                        ballTracer.Color=col; ballTracer.From=Vector2.new(vp.X/2,vp.Y)
                        ballTracer.To=sp; ballTracer.Visible=true
                    else ballTracer.Visible=false end
                else hideBallESP() end
            else hideBallESP() end
        else hideBallESP() end

        -- Player ESP + Auto Dribble
        local plrOn    = get("plr_esp")
        local boxOn    = get("plr_boxes")
        local tracerOn = get("plr_tracer")
        local nameOn   = get("plr_name")
        local speedOn  = get("plr_speed")
        local teamChk  = get("plr_tc")
        local maxDist  = (get("plr_dist") or 200)
        local boxCol   = getColor("plr_box_col")
        local dribOn   = get("auto_dribble")
        local dribR    = get("dribble_fov") or 30
        local myHRP    = getHRP()
        local vp       = camera.ViewportSize
        local myX, myZ
        if myHRP then
            local mx,my,mz = readPosInst(myHRP)
            if mx then myX=mx; myZ=mz end
        end

        local activePls = {}

        for _, player in ipairs(players:GetPlayers()) do
            if player == lp then continue end
            local pname = player.Name
            activePls[pname] = true

            local slot = getOrCreateSlot(pname)

            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then hideSlot(slot); continue end

            local x,y,z = readPosInst(hrp)
            if not x then hideSlot(slot); continue end

            -- Speed calc (raw for dribble, smoothed for ESP)
            local ld = espData[pname]
            local rawSpeed = 0; local speed = 0
            if ld and (now - ld.time) > 0 then
                local dt = now - ld.time
                local ddx, ddz = x-ld.x, z-ld.z
                rawSpeed = math.sqrt(ddx*ddx+ddz*ddz) / dt
                speed = ld.speed + (rawSpeed - ld.speed) * 0.25
            elseif ld then
                speed = ld.speed
            end
            espData[pname] = {x=x,y=y,z=z,time=now,speed=speed}

            -- Auto dribble avg update only here (detection in dedicated loop)
            if isEnemy(player) then
                if not dribData[pname] then
                    dribData[pname] = {avg=rawSpeed, samples=1, lastFired=0, prevDist=0}
                end
                local dd = dribData[pname]
                if rawSpeed > 1 then
                    dd.samples = dd.samples + 1
                    dd.avg = dd.avg + (rawSpeed - dd.avg) * 0.15
                end
            end

            -- ── ESP rendering ───────────────────────────────
            if not plrOn then hideSlot(slot); continue end
            if teamChk and not isEnemy(player) then hideSlot(slot); continue end

            local cp = camera.Position
            local dx2,dy2,dz2 = x-cp.X, y-cp.Y, z-cp.Z
            if dx2*dx2+dy2*dy2+dz2*dz2 > maxDist*maxDist then hideSlot(slot); continue end

            local sp, onScreen = WorldToScreen(Vector3.new(x, y+3, z))
            if not onScreen then hideSlot(slot); continue end

            -- Bottom of box for tracer
            local spBot, onBot = WorldToScreen(Vector3.new(x, y-3, z))

            local col = speedColor(speed)

            if nameOn or speedOn then
                local parts = {}
                if nameOn  then parts[#parts+1] = pname end
                if speedOn then parts[#parts+1] = string.format("[%.0f]", speed) end
                slot.name_lbl.Text     = table.concat(parts,"  ")
                slot.name_lbl.Color    = col
                slot.name_lbl.Position = Vector2.new(sp.X, sp.Y-20)
                slot.name_lbl.Visible  = true
            else slot.name_lbl.Visible=false end

            -- Tracer from bottom of screen to BOTTOM of player box
            if tracerOn then
                local tracerTarget = (onBot and spBot) or sp
                slot.tracer.From=Vector2.new(vp.X/2,vp.Y)
                slot.tracer.To=tracerTarget
                slot.tracer.Color=col; slot.tracer.Visible=true
            else slot.tracer.Visible=false end

            if boxOn then
                if onBot then
                    local bh  = math.max(1, math.abs(sp.Y-spBot.Y))
                    local bw  = bh*0.55
                    local bxp = sp.X - bw/2
                    slot.box.Position=Vector2.new(bxp,sp.Y); slot.box.Size=Vector2.new(bw,bh)
                    slot.box.Color=boxCol; slot.box.Visible=true
                    drawESPCorners(slot.corners,bxp,sp.Y,bw,bh,boxCol)
                else
                    slot.box.Visible=false
                    for _,l in ipairs(slot.corners) do l.Visible=false end
                end
            else
                slot.box.Visible=false
                for _,l in ipairs(slot.corners) do l.Visible=false end
            end
        end

        for name in pairs(espObjects) do
            if not activePls[name] then removeSlot(name) end
        end

        task.wait(0.016)
    end

    hideBallESP()
    for name in pairs(espObjects) do removeSlot(name) end
    pcall(function() ballBox:Remove() end)
    pcall(function() ballTracer:Remove() end)
    pcall(function() ballLabel:Remove() end)
end)

