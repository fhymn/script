-- ============================================================
-- Auto goal
-- ============================================================
local lastScoreTime=0
local function doArc(ball)
    local tx,ty,tz=TARGET.x,TARGET.y,TARGET.z
    local collider=ball:FindFirstChild("Collider")
    local cb=getMemBase(ball); local cc=collider and getMemBase(collider)
    if not cb then return end
    wait(LAUNCH_DELAY); if not running then return end
    cb=getMemBase(ball); cc=collider and getMemBase(collider)
    if not cb then return end
    local sx,sy,sz=readPosMem(cb)
    if sy<MIN_SHOT_HEIGHT then return end
    local dist=math.sqrt((tx-sx)^2+(tz-sz)^2)
    if dist<5 then return end
    local travelTime=math.min(MAX_TRAVEL_TIME,math.max(0.9,dist*0.02))
    local arcHeight=math.max(5,dist*0.15)
    local startTime=tick()
    while running do
        local t=(tick()-startTime)/travelTime
        if t>=1 then
            pcall(function() writePosBase(cb,tx,ty,tz); if cc then writePosBase(cc,tx,ty,tz) end end)
            lastScoreTime=tick(); break
        end
        local et=easeInOut(t)
        local ix=sx+(tx-sx)*et; local iz=sz+(tz-sz)*et
        local iy=sy+(ty-sy)*et+arcHeight*math.sin(t*math.pi)
        pcall(function() writePosBase(cb,ix,iy,iz); if cc then writePosBase(cc,ix,iy,iz) end end)
        task.wait()
    end
end

local lastBX,lastBZ=nil,nil; local inFlight=false; local m1HoldStart=nil
task.spawn(function()
    while running do
        wait(POLL)
        if ismouse1pressed() then
            if not m1HoldStart then m1HoldStart=tick() end
        else m1HoldStart=nil end

        if not UI.GetValue("auto_goal") then
            inFlight=false; lastBX,lastBZ=nil,nil
        else
            local ball=getBall()
            if not ball then inFlight=false; lastBX,lastBZ=nil,nil
            else
                local bb=getMemBase(ball)
                if bb then
                    local bx,by,bz=readPosMem(bb)
                    if not lastBX then lastBX,lastBZ=bx,bz end
                    local delta=math.sqrt((bx-lastBX)^2+(bz-lastBZ)^2)
                    local holdDur=m1HoldStart and (tick()-m1HoldStart) or 0
                    if not inFlight and delta>TRIGGER_DELTA and by>MIN_SHOT_HEIGHT
                        and (tick()-lastScoreTime)>SCORE_COOLDOWN and holdDur>=M1_HOLD_MIN then
                        local d=math.sqrt((TARGET.x-bx)^2+(TARGET.y-by)^2+(TARGET.z-bz)^2)
                        if d>5 then
                            inFlight=true
                            task.spawn(function() doArc(ball); inFlight=false end)
                        end
                    end
                    if delta<0.01 then inFlight=false end
                    lastBX=bx; lastBZ=bz
                end
            end
        end
    end
end)

