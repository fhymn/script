task.spawn(function()
    while running do
        local now = tick()

        -- Ball ESP
        if get("ball_esp") then
            local ball = getBall()
            if ball then
                local bpos = ball.Position
                local sp, onScreen = WorldToScreen(bpos)
                if onScreen then
                    local hrp  = getHRP()
                    local dist = 0
                    if hrp then
                        local hp = hrp.Position
                        dist = math.floor(math.sqrt((bpos.X-hp.X)^2+(bpos.Y-hp.Y)^2+(bpos.Z-hp.Z)^2))
                    end
                    local cp = camera.Position
                    local cd = math.max(1, math.sqrt((bpos.X-cp.X)^2+(bpos.Y-cp.Y)^2+(bpos.Z-cp.Z)^2))
                    local bs = math.max(8, math.min(60, 3000/cd))
                    local hf = bs/2
                    local col = get("rainbow") and rainbowColor(0.66) or getColor("ball_col")
                    local vp  = camera.ViewportSize
                    ballBox.Color=col; ballBox.Position=Vector2.new(sp.X-hf,sp.Y-hf)
                    ballBox.Size=Vector2.new(bs,bs); ballBox.Visible=true
                    ballLabel.Size=get("esp_scale") or 14; ballLabel.Text=dist.."m"; ballLabel.Color=get("rainbow") and rainbowColor(0.66) or Color3.fromRGB(255,255,255)
                    ballLabel.Position=Vector2.new(sp.X,sp.Y-hf-16); ballLabel.Visible=true
                    if get("plr_tracer") then
                        ballTracer.Color=col; ballTracer.From=Vector2.new(vp.X/2,vp.Y)
                        ballTracer.To=sp; ballTracer.Visible=true
                    else ballTracer.Visible=false end
                else hideBallESP() end
            else hideBallESP() end
        else hideBallESP() end

        -- Player ESP + Auto Dribble
        local plrOn    = get("plr_esp")
        local boxOn    = get("plr_boxes")
        local tracerOn = get("plr_tracer")
        local nameOn   = get("plr_name")
        local speedOn  = get("plr_speed")
        local teamChk  = get("plr_tc")
        local maxDist  = (get("plr_dist") or 200)
        local boxCol   = getColor("plr_box_col")
        local dribOn   = get("auto_dribble")
        local dribR    = get("dribble_fov") or 30
        local myHRP    = getHRP()
        local vp       = camera.ViewportSize
        local myX, myZ
        if myHRP then
            local mx,my,mz = readPosInst(myHRP)
            if mx then myX=mx; myZ=mz end
        end

        local activePls = {}

        for _, player in ipairs(players:GetPlayers()) do
            if player == lp then continue end
            local pname = player.Name
            activePls[pname] = true

            local slot = getOrCreateSlot(pname)

            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then hideSlot(slot); continue end

            local x,y,z = readPosInst(hrp)
            if not x then hideSlot(slot); continue end

            -- Speed calc (raw for dribble, smoothed for ESP)
            local ld = espData[pname]
            local rawSpeed = 0; local speed = 0
            if ld and (now - ld.time) > 0 then
                local dt = now - ld.time
                local ddx, ddz = x-ld.x, z-ld.z
                rawSpeed = math.sqrt(ddx*ddx+ddz*ddz) / dt
                speed = (ld.speed or 0) + (rawSpeed - (ld.speed or 0)) * 0.25
            elseif ld then
                speed = ld.speed or 0
            end
            espData[pname] = {x=x,y=y,z=z,time=now,speed=speed}

            -- Auto dribble avg update — never track self
            if player == lp then dribData[pname]=nil end
            if isEnemy(player) and myX and player ~= lp then
                local dribR3 = get("dribble_fov") or 30
                local pdist = math.sqrt((myX-x)^2+(myZ-z)^2)
                if pdist <= dribR3 then
                    if not dribData[pname] then
                        dribData[pname] = {avg=rawSpeed, samples=1, lastFired=0, prevDist=pdist}
                    end
                    local dd = dribData[pname]
                    if rawSpeed > 1 then
                        dd.samples = dd.samples + 1
                        dd.avg = dd.avg + (rawSpeed - dd.avg) * 0.15
                    end
                end
            end

            -- ── ESP rendering ───────────────────────────────
            if not plrOn then hideSlot(slot); continue end
            if teamChk and not isEnemy(player) then hideSlot(slot); continue end

            local cp = camera.Position
            local dx2,dy2,dz2 = x-cp.X, y-cp.Y, z-cp.Z
            if dx2*dx2+dy2*dy2+dz2*dz2 > maxDist*maxDist then hideSlot(slot); continue end

            local sp, onScreen = WorldToScreen(Vector3.new(x, y+3, z))
            if not onScreen then hideSlot(slot); continue end

            -- Bottom of box for tracer
            local spBot, onBot = WorldToScreen(Vector3.new(x, y-3, z))

            local col = get("rainbow") and rainbowColor(speed/200) or speedColor(speed)

            if nameOn or speedOn then
                local parts = {}
                if nameOn  then parts[#parts+1] = pname end
                if speedOn then parts[#parts+1] = string.format("[%.0f]", speed) end
                slot.name_lbl.Text     = table.concat(parts,"  ")
                slot.name_lbl.Color    = col
                slot.name_lbl.Font     = getFont()
                slot.name_lbl.Size     = get("esp_scale") or 14
                slot.name_lbl.Position = Vector2.new(sp.X, sp.Y-20)
                slot.name_lbl.Visible  = true
            else slot.name_lbl.Visible=false end

            -- Tracer from bottom of screen to BOTTOM of player box
            if tracerOn then
                local tracerTarget = (onBot and spBot) or sp
                slot.tracer.From=Vector2.new(vp.X/2,vp.Y)
                slot.tracer.To=tracerTarget
                slot.tracer.Color=col; slot.tracer.Visible=true
            else slot.tracer.Visible=false end

            if boxOn then
                if onBot then
                    local bh  = math.max(1, math.abs(sp.Y-spBot.Y))
                    local bw  = bh*0.55
                    local bxp = sp.X - bw/2
                    slot.box.Position=Vector2.new(bxp,sp.Y); slot.box.Size=Vector2.new(bw,bh)
                    local bCol = get("rainbow") and rainbowColor(0.1) or boxCol
                    slot.box.Color=bCol; slot.box.Visible=true
                    drawESPCorners(slot.corners,bxp,sp.Y,bw,bh,bCol)
                else
                    slot.box.Visible=false
                    for _,l in ipairs(slot.corners) do l.Visible=false end
                end
            else
                slot.box.Visible=false
                for _,l in ipairs(slot.corners) do l.Visible=false end
            end
        end

        for name in pairs(espObjects) do
            if not activePls[name] then removeSlot(name) end
        end

        task.wait(0.016)
    end

    hideBallESP()
    for name in pairs(espObjects) do removeSlot(name) end
    pcall(function() ballBox:Remove() end)
    pcall(function() ballTracer:Remove() end)
    pcall(function() ballLabel:Remove() end)
end)

-- ============================================================
-- Auto Dribble — relative velocity + interception detection
-- ============================================================
local lastMyX, lastMyZ, lastMyTime = nil, nil, nil

task.spawn(function()
    while running do
        local now = tick()
        local dribOn = get("auto_dribble")
        local dribR2 = get("dribble_fov") or 30

        -- Ball possession check
        local weBallX, weBallZ
        local ballInst = getBall()
        if ballInst then
            local bbase = getMemBase(ballInst)
            if bbase then
                local bbx,_,bbz = readPosMem(bbase)
                weBallX=bbx; weBallZ=bbz
            end
        end

        -- Our position + velocity
        local myHRPCheck = getHRP()
        local myPX, myPZ
        if myHRPCheck then
            local ppx,_,ppz = readPosInst(myHRPCheck)
            myPX=ppx; myPZ=ppz
        end
        local weHaveBallNow = weBallX and myPX and math.sqrt((weBallX-myPX)^2+(weBallZ-myPZ)^2) < 6

        -- Our own velocity (needed for relative speed)
        local myVX, myVZ = 0, 0
        if myPX and lastMyX then
            local dtm = math.max(now - (lastMyTime or now), 0.001)
            myVX = (myPX - lastMyX) / dtm
            myVZ = (myPZ - lastMyZ) / dtm
        end
        lastMyX, lastMyZ, lastMyTime = myPX, myPZ, now

        for _, player in ipairs(players:GetPlayers()) do
            if player.Name == lp.Name then continue end
            if not isEnemy(player) then continue end
            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            local x,y,z = readPosInst(hrp)
            if not x then continue end

            local pname = player.Name
            if not dribData[pname] then
                dribData[pname] = {avg=0, lastFired=0, lastX=x, lastZ=z, lastTime=now}
            end
            local dd = dribData[pname]

            local dt2 = math.max(now - (dd.lastTime or now), 0.001)

            -- Enemy absolute velocity
            local evx = dd.lastX and (x - dd.lastX) / dt2 or 0
            local evz = dd.lastZ and (z - dd.lastZ) / dt2 or 0
            dd.lastX=x; dd.lastZ=z; dd.lastTime=now

            -- Update rolling avg of absolute speed (for reference)
            local absSpeed = math.sqrt(evx*evx+evz*evz)
            dd.avg = (dd.avg or 0) + (absSpeed - (dd.avg or 0)) * 0.12

            -- Only check if dribble on and we exist
            if not dribOn or not myPX then continue end

            -- Relative velocity (enemy velocity minus ours)
            local rvx = evx - myVX
            local rvz = evz - myVZ
            local relSpeed = math.sqrt(rvx*rvx + rvz*rvz)

            -- Direction from enemy TO us
            local dx = myPX - x
            local dz = myPZ - z
            local dist = math.sqrt(dx*dx + dz*dz)
            if dist > dribR2 then continue end

            local dirX = dx / math.max(dist, 0.001)
            local dirZ = dz / math.max(dist, 0.001)

            -- Dot product: are they moving toward us?
            local approachDot = rvx * dirX + rvz * dirZ

            -- Time to reach us at current relative speed
            local timeToReach = dist / math.max(relSpeed, 0.001)

            -- Angle check: must be somewhat directly approaching
            local angleCheck = approachDot / math.max(relSpeed, 1)

            local avg = dd.avg or 0
            local relSpeedTrigger = math.max(18, avg * 1.4)

            local isFastRelative = relSpeed > relSpeedTrigger
            local isApproaching  = approachDot > 8
            local willReachSoon  = timeToReach < 0.35
            local angleOk        = angleCheck > 0.5  -- at least 60deg toward us

            if isFastRelative and isApproaching and willReachSoon and angleOk
                and (now - (dd.lastFired or 0)) > 0.25
                and not weHaveBallNow then
                dd.lastFired = now
                pressQ(pname)
            end
        end
        task.wait(0.008)
    end
end)

-- ============================================================
-- Ring drawing helper
-- ============================================================
-- style: 0=solid, 1=dashed, 2=dotted, 3=animated rotating dotted
local ringAnimOffset = 0
local lastRingTick   = tick()

local function drawRing(lines, hrpPos, radius, groundOffset, style, color, thick)
    local vp  = camera.ViewportSize
    local now = tick()

    -- Advance animation offset
    local dt = now - lastRingTick
    lastRingTick = now
    rainbowHue = (rainbowHue + dt * 0.15) % 1
    if style == 3 then
        ringAnimOffset = (ringAnimOffset + dt * 0.6) % 1
    end

    local pts = {}
    for i = 1, FOV_SEGMENTS do
        local a = (i/FOV_SEGMENTS)*math.pi*2
        local wp = Vector3.new(hrpPos.X+math.cos(a)*radius, hrpPos.Y+groundOffset, hrpPos.Z+math.sin(a)*radius)
        local sp, on = WorldToScreen(wp)
        local valid = (on==true) and sp~=nil and sp.X>-200 and sp.X<vp.X+200 and sp.Y>-200 and sp.Y<vp.Y+200
        pts[i] = {sp=(sp or Vector2.new(0,0)), valid=valid}
    end

    for i = 1, FOV_SEGMENTS do
        local line = lines[i]
        local hide = false
        if style == 1 then
            -- Dashed: alternating equal segments
            hide = (i%4 < 2)
        elseif style == 2 then
            -- Dotted: 1 segment visible, 4 hidden = tight dots like the image
            hide = (i%2 ~= 0)
        elseif style == 3 then
            -- Dotted Animated: continuous smooth rotation using fractional phase
            local phase = ((i / FOV_SEGMENTS) + ringAnimOffset) % 1
            -- Sine wave: smooth on/off instead of hard cut
            hide = (math.sin(phase * math.pi * FOV_SEGMENTS / 2) < 0)
        end
        if hide then line.Visible=false; continue end

        local a = pts[i]; local b = pts[(i%FOV_SEGMENTS)+1]
        if a.valid and b.valid then
            local sl = math.sqrt((a.sp.X-b.sp.X)^2+(a.sp.Y-b.sp.Y)^2)
            if sl < 400 then
                -- Dotted styles: draw tiny segment (3px) at pt[i] toward pt[i+1]
                local isDot = (style == 2 or style == 3)
                local toX, toY
                if isDot then
                    local dx = b.sp.X - a.sp.X
                    local dy = b.sp.Y - a.sp.Y
                    local len = math.max(0.001, math.sqrt(dx*dx+dy*dy))
                    toX = a.sp.X + (dx/len)*3
                    toY = a.sp.Y + (dy/len)*3
                else
                    toX = b.sp.X; toY = b.sp.Y
                end
                line.From=a.sp; line.To=Vector2.new(toX,toY)
                if color then line.Color=color end
                if thick then line.Thickness=thick end
                line.Visible=true
            else line.Visible=false end
        else line.Visible=false end
    end
end

-- ============================================================
-- FOV + Auto Block
-- ============================================================
local function updateFOV()
    local hrp = getHRP()

    local showCircles = get("show_circles")
    if not get("auto_block") or not hrp or not showCircles then
        hideFOV(); fovCircle.Visible=false; prevBallY=nil
    else
        local fovR = get("fov_radius") or FOV_WORLD_RADIUS
        local fovStyle = get("fov_style") or 0
        local fovCol   = get("rainbow") and rainbowColor(0) or getColor("fov_color")
        local fovThick = get("fov_thick") or 2
        if fovStyle == 4 then
            -- Native circle: project center+edge to get screen radius
            local sp0, on0 = WorldToScreen(Vector3.new(hrp.Position.X, hrp.Position.Y-3, hrp.Position.Z))
            local spE, onE = WorldToScreen(Vector3.new(hrp.Position.X+fovR, hrp.Position.Y-3, hrp.Position.Z))
            for _,l in ipairs(fovLines) do l.Visible=false end
            if on0 and onE then
                fovCircle.Position=sp0; fovCircle.Radius=math.abs(spE.X-sp0.X)
                fovCircle.Color=fovCol; fovCircle.Thickness=fovThick; fovCircle.Visible=true
            else fovCircle.Visible=false end
        else
            fovCircle.Visible=false
            drawRing(fovLines, hrp.Position, fovR, -3, fovStyle, fovCol, fovThick)
        end
    end

    if not get("auto_dribble") or not hrp or not showCircles then
        hideDribFOV(); dribCircle.Visible=false
    else
        local dribR     = get("dribble_fov") or 30
        local dribStyle = get("drib_style") or 1
        local dribCol   = get("rainbow") and rainbowColor(0.33) or getColor("drib_color")
        local dribThick = get("drib_thick") or 1
        if dribStyle == 4 then
            local sp0, on0 = WorldToScreen(Vector3.new(hrp.Position.X, hrp.Position.Y-3, hrp.Position.Z))
            local spE, onE = WorldToScreen(Vector3.new(hrp.Position.X+dribR, hrp.Position.Y-3, hrp.Position.Z))
            for _,l in ipairs(dribLines) do l.Visible=false end
            if on0 and onE then
                dribCircle.Position=sp0; dribCircle.Radius=math.abs(spE.X-sp0.X)
                dribCircle.Color=dribCol; dribCircle.Thickness=dribThick; dribCircle.Visible=true
            else dribCircle.Visible=false end
        else
            dribCircle.Visible=false
            drawRing(dribLines, hrp.Position, dribR, -3, dribStyle, dribCol, dribThick)
        end
    end

    if not get("auto_block") or not hrp then return end

    local hrpPos = hrp.Position
    local fovR   = get("fov_radius") or FOV_WORLD_RADIUS
    local vp     = camera.ViewportSize

    local ball = getBall()
    if not ball then stealWarn.Visible=false; prevBallY=nil; return end
    local ballPos = ball.Position
    local distXZ  = math.sqrt((ballPos.X-hrpPos.X)^2+(ballPos.Z-hrpPos.Z)^2)
    local inFOV   = distXZ <= fovR

    local shouldBlock = true
    if get("block_tc") then
        shouldBlock = false
        for _, p in ipairs(players:GetPlayers()) do
            if p ~= lp and isEnemy(p) then
                local ch = p.Character
                local eh = ch and ch:FindFirstChild("HumanoidRootPart")
                if eh then
                    local ep = eh.Position
                    local ed = math.sqrt((ep.X-hrpPos.X)^2+(ep.Z-hrpPos.Z)^2)
                    if ed <= fovR then shouldBlock=true; break end
                end
            end
        end
    end

    -- Don't block if WE are currently shooting
    local weAreShooting = m1HoldStart ~= nil and (tick()-m1HoldStart) >= M1_HOLD_MIN

    local velY = 0; pcall(function() velY = ball.AssemblyLinearVelocity.Y end)
    local ballRising = velY >= VEL_Y_THRESHOLD
                    or (prevBallY ~= nil and ballPos.Y - prevBallY >= POS_DELTA_Y)
    local ballAboveFloor = ballPos.Y > 2.5

    -- Require ball to be above minimum height AND moving upward
    -- Extra bounce check: ball must have been below this height recently
    local isBounce = prevBallY ~= nil and prevBallY < 3.5 and ballPos.Y < 5.0

    if inFOV and shouldBlock and not weAreShooting then
        if ballRising and ballAboveFloor and not isBounce then
            stealWarn.Text="AUTO BLOCK!"
            stealWarn.Position=Vector2.new(vp.X/2,vp.Y/2-80)
            stealWarn.Visible=true; setFOVColor(255,60,60); doBlock()
        else
            stealWarn.Visible=false
        end
    else
        stealWarn.Visible=false
    end
    prevBallY = ballPos.Y
end

