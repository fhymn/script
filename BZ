local espObjects = {}
local espData    = {}

local function getOrCreateSlot(name)
    if espObjects[name] then return espObjects[name] end
    local corners = {}
    for i = 1,8 do
        local l = Drawing.new("Line"); l.Visible=false; l.Thickness=2
        l.Color=Color3.fromRGB(255,255,255); corners[i]=l
    end
    local box = Drawing.new("Square")
    box.Visible=false; box.Filled=false; box.Thickness=1; box.Color=Color3.fromRGB(255,255,255)
    local name_lbl = Drawing.new("Text")
    name_lbl.Visible=false; name_lbl.Size=14; name_lbl.Center=true; name_lbl.Outline=true
    name_lbl.Color=Color3.fromRGB(255,255,255)
    local tracer = Drawing.new("Line")
    tracer.Visible=false; tracer.Thickness=1; tracer.Color=Color3.fromRGB(255,255,255)
    espObjects[name] = {name_lbl=name_lbl, tracer=tracer, box=box, corners=corners}
    return espObjects[name]
end

local function hideSlot(s)
    if not s then return end
    s.name_lbl.Visible=false; s.tracer.Visible=false; s.box.Visible=false
    for _,l in ipairs(s.corners) do l.Visible=false end
end

local function removeSlot(name)
    local s = espObjects[name]
    if not s then return end
    pcall(function() s.name_lbl:Remove() end)
    pcall(function() s.tracer:Remove() end)
    pcall(function() s.box:Remove() end)
    for _,l in ipairs(s.corners) do pcall(function() l:Remove() end) end
    espObjects[name]=nil; espData[name]=nil; dribData[name]=nil
end

local function drawESPCorners(corners,bx,by,bw,bh,col)
    local cl=math.min(bw,bh)*0.25
    local pts={
        {Vector2.new(bx,by),       Vector2.new(bx+cl,by)},
        {Vector2.new(bx,by),       Vector2.new(bx,by+cl)},
        {Vector2.new(bx+bw,by),    Vector2.new(bx+bw-cl,by)},
        {Vector2.new(bx+bw,by),    Vector2.new(bx+bw,by+cl)},
        {Vector2.new(bx,by+bh),    Vector2.new(bx+cl,by+bh)},
        {Vector2.new(bx,by+bh),    Vector2.new(bx,by+bh-cl)},
        {Vector2.new(bx+bw,by+bh), Vector2.new(bx+bw-cl,by+bh)},
        {Vector2.new(bx+bw,by+bh), Vector2.new(bx+bw,by+bh-cl)},
    }
    for i,c in ipairs(pts) do
        corners[i].From=c[1]; corners[i].To=c[2]; corners[i].Color=col; corners[i].Visible=true
    end
end

