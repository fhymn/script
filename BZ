local rainbowHue = 0
local function rainbowColor(offset)
    offset = offset or 0
    local h = ((rainbowHue or 0) + offset) % 1
    local r,g,b
    local i = math.floor(h*6); local f = h*6-i
    local q = 1-f
    if i%6==0 then r,g,b=1,f,0
    elseif i%6==1 then r,g,b=q,1,0
    elseif i%6==2 then r,g,b=0,1,f
    elseif i%6==3 then r,g,b=0,q,1
    elseif i%6==4 then r,g,b=f,0,1
    else r,g,b=1,0,q end
    return Color3.new(r,g,b)
end
local function getColor(id)
    local ok, r, g, b, a = pcall(function() return UI.GetValue(id) end)
    if not ok then return Color3.fromRGB(255,165,0) end
    if type(r) == "number" then return Color3.new(r, g or 1, b or 1) end
    if type(r) == "userdata" then return r end
    return Color3.fromRGB(255,165,0)
end

