-- Auto Dribble — dedicated fast loop (no print, no logging)
-- ============================================================
task.spawn(function()
    while running do
        if get("auto_dribble") then
            local now = tick()
            local myHRP2 = getHRP()
            local myX2, myZ2
            if myHRP2 then
                local mx,my,mz = readPosInst(myHRP2)
                if mx then myX2=mx; myZ2=mz end
            end
            local dribR2 = get("dribble_fov") or 30

            if myX2 then
                for _, player in ipairs(players:GetPlayers()) do
                    if player == lp then continue end
                    if not isEnemy(player) then continue end
                    local char = player.Character
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then continue end
                    local x,y,z = readPosInst(hrp)
                    if not x then continue end

                    local pname = player.Name
                    local dd = dribData[pname]
                    if not dd then continue end

                    local dist = math.sqrt((myX2-x)^2+(myZ2-z)^2)
                    if dist > dribR2 then dd.prevDist=dist; continue end

                    -- Compute raw speed from dd's last known position
                    local dt = now - (dd.lastTime or now)
                    local rawSpeed2 = 0
                    if dt > 0 and dd.lastX then
                        local ddx = x - dd.lastX
                        local ddz = z - dd.lastZ
                        rawSpeed2 = math.sqrt(ddx*ddx+ddz*ddz) / dt
                    end
                    dd.lastX=x; dd.lastZ=z; dd.lastTime=now

                    local playerAvg = dd.avg or 0
                    local dynamicThreshold = playerAvg >= 25
                        and math.max(35, playerAvg * 1.4) or 90
                    local effectiveThreshold = dist < 8 and dynamicThreshold or 85
                    local approachThreshold = playerAvg >= 25 and playerAvg * 1.2 or 90
                    local isApproaching = dd.prevDist and (dd.prevDist - dist) > 1.5
                    local earlyTrigger = isApproaching and dist <= 20 and rawSpeed2 >= approachThreshold

                    if (rawSpeed2 >= effectiveThreshold or earlyTrigger)
                        and (now - (dd.lastFired or 0)) > 0.35 then
                        dd.lastFired = now
                        pressQ(pname)
                    end
                    dd.prevDist = dist
                end
            end
        end
        task.wait(0.008)  -- 120hz — twice as fast as ESP loop
    end
end)

-- ============================================================
-- Ring drawing helper
-- ============================================================
local function drawRing(lines, hrpPos, radius, groundOffset, skip)
    local vp = camera.ViewportSize
    local pts = {}
    for i = 1, FOV_SEGMENTS do
        local a = (i/FOV_SEGMENTS)*math.pi*2
        local wp = Vector3.new(hrpPos.X+math.cos(a)*radius, hrpPos.Y+groundOffset, hrpPos.Z+math.sin(a)*radius)
        local sp, on = WorldToScreen(wp)
        local valid = (on==true) and sp~=nil and sp.X>-200 and sp.X<vp.X+200 and sp.Y>-200 and sp.Y<vp.Y+200
        pts[i] = {sp=(sp or Vector2.new(0,0)), valid=valid}
    end
    for i = 1, FOV_SEGMENTS do
        local line = lines[i]
        if skip and (i%2==0) then line.Visible=false; continue end
        local a = pts[i]; local b = pts[(i%FOV_SEGMENTS)+1]
        if a.valid and b.valid then
            local sl = math.sqrt((a.sp.X-b.sp.X)^2+(a.sp.Y-b.sp.Y)^2)
            if sl < 400 then line.From=a.sp; line.To=b.sp; line.Visible=true else line.Visible=false end
        else line.Visible=false end
    end
end

-- ============================================================
-- FOV + Auto Block
-- ============================================================
local function updateFOV()
    local hrp = getHRP()

    if not get("auto_block") or not hrp then
        hideFOV(); prevBallY=nil
    else
        local fovR = get("fov_radius") or FOV_WORLD_RADIUS
        drawRing(fovLines, hrp.Position, fovR, -3, false)
    end

    if not get("auto_dribble") or not hrp then
        hideDribFOV()
    else
        local dribR = get("dribble_fov") or 30
        drawRing(dribLines, hrp.Position, dribR, -3, true)
    end

    if not get("auto_block") or not hrp then return end

    local hrpPos = hrp.Position
    local fovR   = get("fov_radius") or FOV_WORLD_RADIUS
    local vp     = camera.ViewportSize

    local ball = getBall()
    if not ball then stealWarn.Visible=false; prevBallY=nil; return end
    local ballPos = ball.Position
    local distXZ  = math.sqrt((ballPos.X-hrpPos.X)^2+(ballPos.Z-hrpPos.Z)^2)
    local inFOV   = distXZ <= fovR

    local shouldBlock = true
    if get("block_tc") then
        shouldBlock = false
        for _, p in ipairs(players:GetPlayers()) do
            if p ~= lp and isEnemy(p) then
                local ch = p.Character
                local eh = ch and ch:FindFirstChild("HumanoidRootPart")
                if eh then
                    local ep = eh.Position
                    local ed = math.sqrt((ep.X-hrpPos.X)^2+(ep.Z-hrpPos.Z)^2)
                    if ed <= fovR then shouldBlock=true; break end
                end
            end
        end
    end

    local velY = 0; pcall(function() velY = ball.AssemblyLinearVelocity.Y end)
    local ballRising = velY >= VEL_Y_THRESHOLD
                    or (prevBallY ~= nil and ballPos.Y - prevBallY >= POS_DELTA_Y)
    local ballAboveFloor = ballPos.Y > 4.0

    if inFOV and shouldBlock then
        if ballRising and ballAboveFloor then
            stealWarn.Text="AUTO BLOCK!"
            stealWarn.Position=Vector2.new(vp.X/2,vp.Y/2-80)
            stealWarn.Visible=true; setFOVColor(255,60,60); doBlock()
        else
            stealWarn.Visible=false; setFOVColor(0,255,0)
        end
    else
        stealWarn.Visible=false
        if inFOV then setFOVColor(255,200,0) else setFOVColor(0,255,0) end
    end
    prevBallY = ballPos.Y
end

-- ============================================================
-- Main loop
-- ============================================================
local f2Was=false
while running do
    local f2=iskeypressed(0x71)
    if f2 and not f2Was then doQueue() end
    f2Was=f2
    pcall(updateFOV)
    task.wait(0.03)
end

