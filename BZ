-- Dynamic hoop detection from Workspace.Hoops
local function getHoopPos(side)
    -- side = "Away" or "Home"
    local ok, hoop = pcall(function()
        return ws.Hoops:FindFirstChild(side):FindFirstChild("Hoop")
    end)
    if ok and hoop then
        local pos = hoop.Position
        return {x=pos.X, y=pos.Y + 0.5, z=pos.Z}  -- +0.5 to aim just above rim center
    end
    return nil
end

local TARGET=nil; local lastTeamName=""
local function updateTarget()
    local tn=lp.Team and lp.Team.Name or ""
    if tn==lastTeamName then return end
    local side
    if string.lower(tn)=="home" then side="Away"
    elseif string.lower(tn)=="away" or string.lower(tn)=="visitor" then side="Home"
    end
    if side then
        local h = getHoopPos(side)
        if h then
            TARGET=h; lastTeamName=tn
            print(string.format("[AutoGoal] Team '%s' -> %s hoop (%.2f,%.2f,%.2f)", tn, side, h.x, h.y, h.z))
        end
    end
end
